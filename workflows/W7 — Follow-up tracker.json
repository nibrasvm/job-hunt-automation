            {
              "id": "59b82f46-939c-4549-8deb-869be5f44625",
              "name": "follow_up_subject",
              "value": "={{ JSON.parse($json.content[0].text.match(/\\{[\\s\\S]*\\}/)[0]).subject.trim() }}\n",
              "type": "string"
            },
            {
              "id": "807ee89e-82ba-4ff7-928a-92a2e6218a7d",
              "name": "follow_up_body",
              "value": "={{ JSON.parse($json.content[0].text.match(/\\{[\\s\\S]*\\}/)[0]).body.trim() }}",
