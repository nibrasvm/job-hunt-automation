        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 400,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ 'You are a professional job applicant writing a follow-up email. Recruiter: ' + ($json.recruiterName ?? 'Hiring Team') + '. Job: ' + ($json.jobTitle ?? 'the role') + '. Company: ' + ($json.company ?? 'your company') + '. Original outreach sent: ' + $json.outreach_date + '. Write a polite follow-up email. Format the body exactly as: start with Dear [first name only], then two blank lines, then one opening sentence, then two blank lines, then 1-2 sentences of follow-up, then two blank lines, then a direct question asking for a status update. Return ONLY valid JSON with keys subject and body. No markdown, no backticks, no closing pleasantries. JSON only.' }}\"\n    }\n  ]\n}",
        "options": {}
      },
