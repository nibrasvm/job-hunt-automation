      "id": "23f7ab00-6029-47e1-b5dd-372597c7aaa0",
      "name": "Get many database pages",
      "credentials": {
        "notionApi": {
          "id": "LU3vC29KAXOorisn",
          "name": "Notion account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const props = item.json.properties;\n\n  // --- Company ---\n  const company =\n    props[\"Company\"]?.rich_text?.[0]?.plain_text ||\n    props[\"Company\"]?.title?.[0]?.plain_text || '';\n\n  // --- Job Title ---\n  const jobTitle =\n    props[\"Job Title\"]?.title?.[0]?.plain_text ||\n    props[\"Job Title\"]?.rich_text?.[0]?.plain_text || '';\n\n  // --- Job Link ---\n  const jobLink = props[\"Job Link\"]?.url || '';\n\n  // --- Domain Extraction ---\n  // Step 1: Try direct URL parse (only works if it's NOT a Google search link)\n  let domain = '';\n  try {\n    if (jobLink && !jobLink.includes('google.com') && !jobLink.includes('linkedin.com')) {\n      const url = new URL(jobLink);\n      domain = url.hostname.replace(/^www\\./, '');\n    }\n  } catch (e) {}\n\n  // Step 2: If domain still empty, derive from company name\n  // Strips common suffixes, removes non-alphanumeric chars, appends .com\n  if (!domain && company) {\n    domain = company\n      .toLowerCase()\n      .replace(/\\s+(inc|ltd|llc|corp|co|plc|ag|gmbh|technologies|technology|tech|solutions|solution|services|systems|group|global|international|consulting|consultancy|network|networks)\\.?\\s*$/i, '')\n      .replace(/\\s+/g, '')        // remove internal spaces\n      .replace(/[^a-z0-9]/g, '')  // remove special chars\n      .trim() + '.com';\n  }\n\n  return {\n    json: {\n      pageId: item.json.id,\n      company: company,\n      jobTitle: jobTitle,\n      jobLink: jobLink,\n      domain: domain\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ],
      "id": "6e351ed8-2e95-44be-9b79-784390f60f07",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.snov.io/v1/oauth/access_token",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"grant_type\": \"client_credentials\",\n  \"client_id\": \"YOUR_SNOV_CLIENT_ID\",\n  \"client_secret\": \"YOUR_SNOV_CLIENT_SECRET\"\n}",
        "options": {}
      },
