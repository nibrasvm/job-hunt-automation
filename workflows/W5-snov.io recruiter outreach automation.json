      "id": "a99cda72-5885-4b4a-be6d-6385db2db25b",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map((item, i) => {\n  // Snov.io returns emails under item.json.emails (array)\n  const emails = item.json.emails || [];\n\n  // Pull pageId/company from Node 3\n  const upstream = $('Code in JavaScript').all()[i]?.json || {};\n\n  // HR/recruiting keyword filter\n  const hrKeywords = ['recruit', 'talent', 'hr', 'human resource', 'people', 'hiring', 'acquisition'];\n\n  const hrEmails = emails.filter(e => {\n    const pos = (e.position || '').toLowerCase();\n    return hrKeywords.some(k => pos.includes(k));\n  });\n\n  // Prefer HR emails; fall back to full list. Sort by confidence desc.\n  const candidates = hrEmails.length > 0 ? hrEmails : emails;\n  candidates.sort((a, b) => {\n    const order = { high: 3, medium: 2, low: 1 };\n    return (order[b.confidence] || 0) - (order[a.confidence] || 0);\n  });\n\n  const best = candidates[0];\n\n  return {\n    json: {\n      pageId: upstream.pageId,\n      company: upstream.company,\n      recruiter_found: !!(best?.email),\n      recruiter_name: best ? `${best.firstName || ''} ${best.lastName || ''}`.trim() : '',\n      recruiter_email: best?.email || '',\n      recruiter_position: best?.position || '',\n      confidence: best?.confidence || 'none'\n    }\n  };\n});"
      },
